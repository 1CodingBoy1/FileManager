#!/bin/bash
DIR="$(cd "$(dirname "$0")" && pwd)"

if [ ! -f "$DIR/server.py" ]; then
    echo "  [!] server.py not found in $DIR"
    exit 1
fi

if ! command -v python3 &> /dev/null; then
    echo "  [!] Python3 is required but not installed."
    exit 1
fi

cd "$DIR"
exec python3 server.py "${1:-8080}" "${2:-0.0.0.0}"
